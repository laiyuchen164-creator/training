{
  "run_name": "belief_r_commitment_test_openai_gpt54mini",
  "seed": 7,
  "data": {
    "dataset_name": "belief_r",
    "raw_dir": "data/raw/belief_r",
    "processed_path": "data/processed/belief_r_incremental_commitment_test_subset.jsonl",
    "stats_path": "data/processed/belief_r_incremental_commitment_test_subset_stats.json",
    "refresh_data": false
  },
  "dataset": {
    "include_conditions": [
      "full_info",
      "incremental_no_overturn",
      "incremental_overturn_reasoning"
    ],
    "sample_size_per_condition": {
      "full_info": 130,
      "incremental_no_overturn": 27,
      "incremental_overturn_reasoning": 103
    }
  },
  "backend": {
    "type": "llm",
    "provider": "openai",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-5.4-mini",
    "fallback_models": [
      "gpt-5-mini",
      "gpt-4.1-mini"
    ],
    "temperature": 0.0,
    "max_tokens": 180,
    "timeout_seconds": 90
  },
  "systems": [
    "source_revision"
  ]
}
