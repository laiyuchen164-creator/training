      "incremental_no_overturn": 15,
      "incremental_overturn_reasoning": 15
    }
  },
  "backend": {
    "type": "llm",
    "provider": "openai",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-5.4-mini",
    "fallback_models": [
      "gpt-5-mini",
      "gpt-4.1-mini"
    ],
    "temperature": 0.0,
    "max_tokens": 180,
    "timeout_seconds": 90
  },
  "systems": [
    "source_revision"
  ],
  "prompt_overrides": {
    "belief_r_source_revision_prompt_version": "v2"
  }
}
