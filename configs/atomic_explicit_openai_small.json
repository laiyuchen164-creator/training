{
  "run_name": "atomic_explicit_openai_small",
  "seed": 17,
  "data": {
    "dataset_name": "atomic_explicit_revision",
    "raw_dir": "data/raw/atomic",
    "processed_path": "data/processed/atomic_explicit_revision.jsonl",
    "stats_path": "data/processed/atomic_explicit_revision_stats.json",
    "refresh_data": false,
    "max_seed_examples": 300
  },
  "dataset": {
    "include_conditions": [
      "full_info",
      "incremental_no_overturn",
      "incremental_overturn_reasoning"
    ],
    "sample_size_per_condition": {
      "full_info": 4,
      "incremental_no_overturn": 4,
      "incremental_overturn_reasoning": 4
    }
  },
  "backend": {
    "type": "llm",
    "provider": "openai",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-5.4-mini",
    "fallback_models": [
      "gpt-5-mini",
      "gpt-4.1-mini"
    ],
    "max_tokens": 120,
    "timeout_seconds": 90
  },
  "systems": [
    "raw_history",
    "running_summary",
    "structured_no_source",
    "source_no_revision",
    "source_revision"
  ]
}
