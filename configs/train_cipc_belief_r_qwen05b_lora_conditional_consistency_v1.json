{
  "run_name": "cipc_belief_r_qwen05b_lora_conditional_consistency_v1",
  "run_dir": "runs/cipc_belief_r_qwen05b_lora_conditional_consistency_v1",
  "analysis_report_path": "analysis/cipc_qwen05b_conditional_consistency_v1_report.md",
  "seed": 7,
  "data": {
    "train_path": "data/processed/belief_r_commitment_control_train.jsonl",
    "dev_path": "data/processed/belief_r_commitment_control_dev.jsonl",
    "test_path": "data/processed/belief_r_commitment_control_test.jsonl",
    "max_dev_examples": 254,
    "max_test_examples": 260
  },
  "labels": {
    "control_labels": ["preserve", "weaken", "replace"],
    "answer_labels": ["a", "b", "c"]
  },
  "model": {
    "name": "Qwen/Qwen2.5-0.5B-Instruct",
    "max_length": 256,
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "use_bf16": true,
    "gradient_checkpointing": false
  },
  "training": {
    "num_epochs": 6,
    "train_batch_size": 4,
    "eval_batch_size": 8,
    "learning_rate": 0.00012,
    "weight_decay": 0.01,
    "gradient_accumulation_steps": 4,
    "answer_loss_weight": 1.0,
    "lambda_prop": 0.3,
    "beta_replace_margin": 0.2,
    "margin_m": 0.5,
    "use_fp16_scaler": false,
    "oversample_control_labels": true
  }
}
