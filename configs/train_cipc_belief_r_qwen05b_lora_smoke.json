{
  "run_name": "cipc_belief_r_qwen05b_lora_smoke",
  "run_dir": "runs/cipc_belief_r_qwen05b_lora_smoke",
  "analysis_report_path": "analysis/cipc_belief_r_qwen05b_lora_smoke_report.md",
  "seed": 7,
  "data": {
    "train_path": "data/processed/belief_r_commitment_control_train.jsonl",
    "dev_path": "data/processed/belief_r_commitment_control_dev.jsonl",
    "test_path": "data/processed/belief_r_commitment_control_test.jsonl",
    "max_train_examples": 512,
    "max_dev_examples": 128,
    "max_test_examples": 128
  },
  "labels": {
    "control_labels": ["preserve", "weaken", "replace"],
    "answer_labels": ["a", "b", "c"]
  },
  "model": {
    "name": "Qwen/Qwen2.5-0.5B-Instruct",
    "max_length": 256,
    "lora_r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "use_bf16": true,
    "gradient_checkpointing": false
  },
  "training": {
    "num_epochs": 1,
    "train_batch_size": 4,
    "eval_batch_size": 8,
    "learning_rate": 0.0002,
    "weight_decay": 0.01,
    "gradient_accumulation_steps": 4,
    "answer_loss_weight": 1.0,
    "use_fp16_scaler": false
  }
}
