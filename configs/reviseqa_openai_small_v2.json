{
  "run_name": "reviseqa_openai_small_v2",
  "seed": 23,
  "data": {
    "dataset_name": "reviseqa_incremental",
    "raw_dir": "data/raw/reviseqa",
    "processed_path": "data/processed/reviseqa_incremental.jsonl",
    "stats_path": "data/processed/reviseqa_incremental_stats.json",
    "refresh_data": false
  },
  "dataset": {
    "include_conditions": [
      "full_info",
      "incremental_no_overturn",
      "incremental_overturn_reasoning"
    ],
    "sample_size_per_condition": {
      "full_info": 4,
      "incremental_no_overturn": 4,
      "incremental_overturn_reasoning": 4
    }
  },
  "backend": {
    "type": "llm",
    "provider": "openai",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-5.4-mini",
    "fallback_models": [
      "gpt-5-mini",
      "gpt-4.1-mini"
    ],
    "max_tokens": 160,
    "timeout_seconds": 90
  },
  "systems": [
    "raw_history",
    "running_summary",
    "structured_no_source",
    "source_no_revision",
    "source_revision"
  ]
}
